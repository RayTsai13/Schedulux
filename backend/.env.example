# Backend Environment Variables
# Copy this file to .env and fill in your values

DB_HOST=localhost
DB_PORT=5432
DB_NAME=schedulux_primary
DB_USER=
DB_PASSWORD=
JWT_SECRET=                         # REQUIRED — app refuses to start if missing
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

# Email (optional in dev — emails log to console if unset)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@schedulux.com
SENDGRID_FROM_NAME=Schedulux

# Frontend URL for email links (password reset, etc.)
# REQUIRED in production — password reset email links will be broken if unset
FRONTEND_URL=http://localhost:5173

# Image Uploads (Cloudinary)
# Optional — upload endpoint returns 503 if not configured
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
